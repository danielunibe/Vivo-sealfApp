{
  "name": "ai-studio-applet",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "eslint app components hooks lib types scripts/*.mjs --ext .js,.jsx,.ts,.tsx,.mjs",
    "android:build:web": "node scripts/build-android-web.mjs",
    "android:sync": "npx cap sync android",
    "android:copy": "npx cap copy android",
    "android:open": "npx cap open android",
    "android:run": "npx cap run android",
    "android:prepare": "npm run lint && npm run android:build:web && npm run android:sync",
    "android:device-qa": "powershell -ExecutionPolicy Bypass -File scripts/android-device-qa.ps1"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@types/three": "^0.184.1",
    "autoprefixer": "^10.5.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "next": "15.0.3",
    "react": "19.0.0-rc.1",
    "react-dom": "19.0.0-rc.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "4.0.0-beta.2",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0-beta.2",
    "@types/node": "25.9.1",
    "@types/react": "19.2.16",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.0.3",
    "typescript": "6.0.3"
  }
}
